    "@astrojs/tailwind": "^5.0.4",
    "@babel/standalone": "^7.26.2",
    "@monaco-editor/react": "^4.6.0",
    "@supabase/supabase-js": "^2.45.6",
    "@types/node": "^22.7.7",
