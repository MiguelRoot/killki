{
  "name": "mypage",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "monaco": "shx mkdir -p dist/static/monaco && shx cp -r node_modules/monaco-editor/min/vs dist/static/monaco/",
    "lax": "shx mkdir -p dist/static/lax && shx cp -r node_modules/lax.js/lib/lax.min.js dist/static/lax/",
    "generateCV": "tsx doc/generateCV",
    "build": "astro check && astro build && npm run generateCV && npm run monaco && npm run lax",
    "preview": "astro preview",
    "astro": "astro",
    "deploy": "gh-pages -d dist"
  },
  "dependencies": {
