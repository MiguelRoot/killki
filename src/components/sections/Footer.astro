---
import AppIcon from "../AppIcon.astro";

// import IconApp from "../shared/astro/IconApp.astro";

const today = new Date();
---

<footer class="bg-primary-50 mt-10">
  <div
    class="mx-auto px-3 md:px-8 max-w-screen-xl py-5 md:flex justify-between items-center"
  >
    <div class="flex items-center justify-center md:justify-start">
      <AppIcon name="logo" size="38" />

      <div class="mx-2">
        <AppIcon name="frog" size="32" />
      </div>

      <!-- <div>
        <IconApp name="code" size="small" />
      </div> -->

      <div class="ms-1">
        &copy; {today.getFullYear()} killki Corporation.
      </div>
    </div>
    <div class="mt-3 md:mt-0 text-center md:text-start">
      Security | Privacy | terms
    </div>
  </div>
</footer>
