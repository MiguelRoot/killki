    <script type="text/javascript">
      // Texto que se moverá
      const text = "😓 ¡A donde vas regresa! ";
      let index = 0;
      let scrollInterval;
      let timeouts = [];
      let hasVisibilityChanged = false;

      // Convertir el texto a un array seguro para manipulación Unicode
      const chars = Array.from(text);

      // Función para mover el texto
      function scrollTitle() {
        document.title =
          chars.slice(index).join("") + chars.slice(0, index).join("");
        index = (index + 1) % chars.length; // Ciclar el texto
      }

      // Cambiar el título de la pestaña con un retraso
      function setTitleWithTimeout(title, delay) {
        const timeoutId = setTimeout(() => {
          document.title = title;
        }, delay);
        timeouts.push(timeoutId);
      }

      function clearAllTimeouts() {
        timeouts.forEach(clearTimeout);
        timeouts = [];
      }

      // Detectar cambios de visibilidad de la pestaña
      document.addEventListener("visibilitychange", () => {
        if (document.hidden) {
          clearAllTimeouts();
          index = 0;
          // Iniciar el efecto cuando la pestaña esté inactiva
          scrollInterval = setInterval(scrollTitle, 100);
          hasVisibilityChanged = true;
        } else {
          if (hasVisibilityChanged) {
            // Detener el efecto cuando el usuario regrese a la pestaña
            clearInterval(scrollInterval);
            document.title = "🤗 Miguel killki"; // Restablecer el título
            setTitleWithTimeout("😏 Miguel killki", 800);
            setTitleWithTimeout("😙 Miguel killki", 1600);
            setTitleWithTimeout("😉 Miguel killki", 2400);
            setTitleWithTimeout("🏃‍♂️ Miguel killki", 3200);
            setTitleWithTimeout("Miguel killki", 4000);
          }
        }
      });
    </script>

