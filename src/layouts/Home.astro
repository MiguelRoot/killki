    <script>
      document.addEventListener("DOMContentLoaded", function () {
        // menu scroll
        const Model = {
          state: {
            currentSection: null as HTMLElement | null,
            navHeight: 0,
          },

          setNavHeight(height: number) {
            this.state.navHeight = height;
          },

          setCurrentSection(section: HTMLElement | null) {
            this.state.currentSection = section;
          },

          getNavHeight() {
            return this.state.navHeight;
          },

          getCurrentSection() {
            return this.state.currentSection;
          },
        };

        const Actions = {
          updateActiveSection(curPos: number) {
            const sections = document.querySelectorAll("section");
            const nav = document.querySelector("nav");
            if (!nav) return;

            const listSection = Array.from(sections)?.map(
              (section) => section.id
            );
            sections.forEach((section) => {
              // console.log(section.id, "section.id");
              const top = section.offsetTop - Model.getNavHeight();
              const bottom = top + section.offsetHeight;

              if (curPos >= top && curPos <= bottom) {
                // console.log(curPos, "curPos init");
                Model.setCurrentSection(section);
                const navLinks = nav.querySelectorAll("a");

                navLinks.forEach((link) => link.classList.remove("active"));
                sections.forEach((sec) => sec.classList.remove("active"));

                section.classList.add("active");

                const sectionId = section.id;
                listSection.forEach((id) => {
                  document.body.classList.remove(id);
                });
                document.body.classList.add(sectionId);
                const activeLink = nav.querySelector(
                  `a[href="#${section.getAttribute("id")}"]`
                );
                activeLink?.classList.add("active");
              }
            });
          },

          scrollToSection(targetId: string) {
            const targetSection = document.querySelector(targetId)!;
            if (!targetSection) return;

            const targetOffsetTop =
              (targetSection as HTMLElement).offsetTop - Model.getNavHeight();
            // console.log(targetOffsetTop);
            window.scrollTo({
              top: targetOffsetTop,
              behavior: "smooth",
            });
          },
        };

        const State = {
          init() {
            const nav = document.querySelector("nav");
            if (!nav) return;

            Model.setNavHeight(nav.offsetHeight - 80);

            window.addEventListener("scroll", () => {
              const curPos = window.scrollY;
              Actions.updateActiveSection(curPos);
            });

            const navLinks = nav.querySelectorAll("a");
            navLinks.forEach((link) => {
              link.addEventListener("click", (e: Event) => {
                e.preventDefault();
                const targetId = link.getAttribute("href");
                if (targetId) {
                  Actions.scrollToSection(targetId);
                }
              });
            });
          },
        };

        const curPos = window.scrollY;
        console.log(curPos);
        Actions.updateActiveSection(curPos);

        // Inicializar el estado
        State.init();
      });
    </script>

    <script type="module" src={scriptSrc}></script>
