<style is:global>
  .anime-item {
    transition: opacity 0.2s;
    /* transform 0.3s; */
  }

  /* Animation Items */
  .anime-item.fade-opacity {
    opacity: 0;
  }
  .anime-item.fade-xr {
    opacity: 0;
    transform: translateX(8px);
  }
  .anime-item.fade-xr-lg {
    opacity: 0;
    transform: translateX(10px);
  }
  @media (min-width: 1024px) {
    .anime-item.fade-xr-lg {
      transform: translateX(30px);
    }
  }
  .anime-item.fade-xl {
    opacity: 0;
    transform: translateX(-8px);
  }
  .anime-item.fade-xl-lg {
    opacity: 0;
    transform: translateX(-10px);
  }
  @media (min-width: 1024px) {
    .anime-item.fade-xl-lg {
      transform: translateX(-30px);
    }
  }
  .anime-item.fade-yb {
    opacity: 0;
    transform: translateY(8px);
  }
  .anime-item.fade-yb-lg {
    opacity: 0;
    transform: translateY(10px);
  }
  @media (min-width: 1024px) {
    .anime-item.fade-yb-lg {
      transform: translateY(30px);
    }
  }
  .anime-item.fade-yt {
    opacity: 0;
    transform: translateY(-8px);
  }
  .anime-item.fade-yt-lg {
    opacity: 0;
    transform: translateY(-10px);
  }
  @media (min-width: 1024px) {
    .anime-item.fade-yt-lg {
      transform: translateY(-30px);
    }
  }

  /* Link Effect 1 */
  .link-left {
    position: relative;
  }
  .link-left::before {
    content: "";
    position: absolute;
    left: 0;
    bottom: -3px;
    width: 100%;
    height: 1px;
    opacity: 1;
    background-color: currentColor;
    transform-origin: bottom right;
    transform: scale(0);
    transition: transform 0.4s ease;
  }
  .link-left:hover::before {
    transform: scaleX(1);
    transform-origin: bottom left;
  }
</style>

