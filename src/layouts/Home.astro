import { i18n, i18nDetail } from "../i18n";
import DonwloadCV from "../components/DonwloadCV.astro";
import AppIcon from "../components/AppIcon.astro";
const { page, lang }: any = Astro.props as {
  page: string;
  lang: string;
};

const isDev = import.meta.env.MODE === "development";
const scriptSrc = isDev
  ? "/node_modules/lax.js/lib/lax.min.js"
  : "/static/lax/lax.min.js";

const { currentLocale } = Astro;


const texts = i18n(currentLocale);
const dataPage = i18nDetail(page, lang);
console.log(dataPage, "dataPage");
// import "../libs/gsap/gsap.css";
